# ─────────────────────────────────────────────
#  Copie para .env.local e preencha os valores
# ─────────────────────────────────────────────

# URL pública do site (sem barra final) — usada nos metadados OG e canonical
# Em produção: https://gabrielricarte.com.br  (ou seu domínio real)
NEXT_PUBLIC_SITE_URL=https://seudominio.com

# ── SMTP para envio de e-mail via formulário de contato ──
# Recomendado: Gmail com App Password (2FA ativado no Google)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app

# E-mail que receberá as mensagens enviadas pelo formulário
# Se omitido, usa gabrielricarte000@gmail.com como padrão
CONTACT_EMAIL=seu-email@gmail.com

# E-mail público usado como fallback no cliente (mailto:) quando a API falha
NEXT_PUBLIC_CONTACT_EMAIL=seu-email@gmail.com
